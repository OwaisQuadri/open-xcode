#!/usr/bin/env bash
set -euo pipefail

VERSION="1.1.0"

usage() {
  cat <<EOF
open-xcode $VERSION — open the right Xcode workspace/project from anywhere in a repo

Usage: open-xcode [options] [name]

Finds the best .xcworkspace/.xcodeproj under the git repo root (or the current
directory) and opens it in Xcode. With a name, matches it case-insensitively
against workspace/project names and paths.

Options:
  -p, --print      print the selection without opening Xcode (alias: --dry-run)
  -l, --list       list all candidates, best match first
  -v, --version    print the version
  -h, --help       show this help

Environment:
  OPEN_XCODE_ROOT  search from this directory instead of the current one

Selection: prefers .xcworkspace over .xcodeproj, prefers /ios/ over sibling
platform folders, breaks ties by most recently used.
EOF
}

print_only=0
list_only=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -v|--version) echo "open-xcode $VERSION"; exit 0 ;;
    -p|--print|--dry-run) print_only=1; shift ;;
    -l|--list) list_only=1; shift ;;
    --) shift; break ;;
    -*) echo "open-xcode: unknown option: $1" >&2; echo "Try 'open-xcode --help' for usage." >&2; exit 2 ;;
    *) break ;;
  esac
done

query="${*:-}"
query="$(printf '%s' "$query" | sed -E 's#^/open-(xcode|ios)[[:space:]]*##I; s#^[Oo]pen[[:space:]]+##; s#\.(xcworkspace|xcodeproj)$##I; s#^[[:space:]]+##; s#[[:space:]]+$##')"

start_dir="${OPEN_XCODE_ROOT:-$PWD}"
if repo_root="$(git -C "$start_dir" rev-parse --show-toplevel 2>/dev/null)"; then
  root="$repo_root"
else
  root="$start_dir"
fi

normalize() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's#\.(xcworkspace|xcodeproj)$##; s#[^a-z0-9]+##g'
}

last_used_epoch() {
  local path="$1"
  local used
  used="$(mdls -raw -name kMDItemLastUsedDate "$path" 2>/dev/null || true)"
  if [[ -n "$used" && "$used" != "(null)" ]]; then
    date -j -f "%Y-%m-%d %H:%M:%S %z" "$used" +%s 2>/dev/null && return 0
  fi
  stat -f %m "$path"
}

declare -a candidates=()
while IFS= read -r -d '' path; do
  candidates+=("$path")
done < <(
  find "$root" \
    \( -type d \( -name .git -o -name Pods -o -name build -o -name Build -o -name DerivedData -o -name .symlinks \) -prune \) -o \
    \( -type d \( -name "*.xcworkspace" -o -name "*.xcodeproj" \) -print0 -prune \)
)

if [[ "${#candidates[@]}" -eq 0 ]]; then
  echo "No .xcworkspace or .xcodeproj found under $root" >&2
  exit 1
fi

query_norm="$(normalize "$query")"
rank_pool() {
  local require_match="$1"
  local prefer_workspace="$2"
  local path base base_norm platform_score type_score match_score epoch inverted_epoch

  for path in "${candidates[@]}"; do
    if [[ "$prefer_workspace" == "1" && "$path" != *.xcworkspace ]]; then
      continue
    fi

    base="$(basename "$path")"
    base_norm="$(normalize "$base")"
    platform_score=50
    [[ "$path" == */ios/* ]] && platform_score=0
    type_score=100
    [[ "$path" == *.xcworkspace ]] && type_score=0

    match_score=50
    if [[ -n "$query_norm" ]]; then
      if [[ "$base_norm" == "$query_norm" ]]; then
        match_score=0
      elif [[ "$base_norm" == *"$query_norm"* || "$query_norm" == *"$base_norm"* ]]; then
        match_score=10
      elif [[ "$(normalize "$path")" == *"$query_norm"* ]]; then
        match_score=20
      elif [[ "$require_match" == "1" ]]; then
        continue
      fi
    fi

    epoch="$(last_used_epoch "$path")"
    inverted_epoch=$((9999999999 - epoch))
    printf '%03d\t%03d\t%03d\t%010d\t%s\n' "$match_score" "$platform_score" "$type_score" "$inverted_epoch" "$path"
  done
}

has_workspace=0
for candidate in "${candidates[@]}"; do
  if [[ "$candidate" == *.xcworkspace ]]; then
    has_workspace=1
    break
  fi
done

ranked="$(
  {
    if [[ -n "$query_norm" ]]; then
      rank_pool 1 0
    elif [[ "$has_workspace" == "1" && "$list_only" != "1" ]]; then
      rank_pool 0 1
    else
      rank_pool 0 0
    fi
  } | sort -t $'\t' -k1,1n -k2,2n -k3,3n -k4,4n | cut -f5-
)"

if [[ -z "$ranked" && -n "$query_norm" ]]; then
  ranked="$(rank_pool 0 "$has_workspace" | sort -t $'\t' -k1,1n -k2,2n -k3,3n -k4,4n | cut -f5-)"
fi

if [[ -z "$ranked" ]]; then
  echo "No matching Xcode workspace/project found under $root" >&2
  exit 1
fi

if [[ "$list_only" == "1" ]]; then
  printf '%s\n' "$ranked"
  exit 0
fi

selected="$(head -n 1 <<<"$ranked")"
echo "$selected"
if [[ "$print_only" != "1" ]]; then
  open "$selected"
fi
